# ============================================================================
# RAG MCP Server 环境变量配置
# 复制本文件为 .env 并填写实际值:  cp .env.example .env
# config.toml 中 ${VAR_NAME} 占位符会自动替换为此处对应的值
# ============================================================================

# ──────────────────────────── Redis ────────────────────────────
REDIS_PASSWORD=your_redis_password

# ──────────────────────────── Embedding Provider (主) ────────────────────────────
# 对应 [[embedding_providers]] name = "primary-dashscope"
EMBEDDING_PRIMARY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_PRIMARY_API_KEY=your_dashscope_api_key
EMBEDDING_PRIMARY_MODEL=text-embedding-v4

# ──────────────────────────── Embedding Provider (备) ────────────────────────────
# 对应 [[embedding_providers]] name = "fallback-openai" (默认 disabled)
EMBEDDING_FALLBACK_BASE_URL=https://api.openai.com/v1
EMBEDDING_FALLBACK_API_KEY=your_openai_api_key
EMBEDDING_FALLBACK_MODEL=text-embedding-3-small

# ──────────────────────────── Rerank 重排序 ────────────────────────────
RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
RERANK_API_KEY=your_dashscope_api_key
RERANK_MODEL=qwen3-rerank

# ──────────────────────────── HyDE 查询扩展 ────────────────────────────
HYDE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
HYDE_API_KEY=your_dashscope_api_key
HYDE_MODEL=qwen-turbo

# ──────────────────────────── Multi-Query 多查询检索 ────────────────────────────
MULTI_QUERY_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MULTI_QUERY_API_KEY=your_dashscope_api_key
MULTI_QUERY_MODEL=qwen-turbo

# ──────────────────────────── Context Compressor 上下文压缩 ────────────────────────────
# 仅 type = "llm" 时需要配置
COMPRESSOR_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
COMPRESSOR_API_KEY=your_dashscope_api_key
COMPRESSOR_MODEL=qwen-turbo

# ──────────────────────────── Graph RAG — Neo4j ────────────────────────────
GRAPH_NEO4J_PASSWORD=your_neo4j_password

# ──────────────────────────── Graph RAG — LLM 实体提取器 ────────────────────────────
# 仅 entity_extractor = "llm" 时需要配置
GRAPH_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GRAPH_LLM_API_KEY=your_dashscope_api_key
GRAPH_LLM_MODEL=qwen-turbo

# ──────────────────────────── VectorStore — Milvus (可选) ────────────────────────────
# 仅 vector_store.type = "milvus" 时需要配置
MILVUS_TOKEN=

# ──────────────────────────── VectorStore — Qdrant (可选) ────────────────────────────
# 仅 vector_store.type = "qdrant" 时需要配置
QDRANT_API_KEY=
